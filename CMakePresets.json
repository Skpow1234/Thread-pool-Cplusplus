{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "configurePresets": [

    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "base-clang",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },

    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "description": "Debug build, no sanitizers",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "description": "Optimised release build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "asan-ubsan",
      "inherits": "base",
      "displayName": "Debug + ASan + UBSan (default compiler)",
      "description": "Requires Clang or GCC; MSVC falls back to plain debug with a warning",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SANITIZE_ASAN_UBSAN": "ON"
      }
    },

    {
      "name": "asan-ubsan-clang",
      "inherits": "base-clang",
      "displayName": "Debug + ASan + UBSan (Clang)",
      "description": "Windows: scoop install llvm ninja  |  Linux/macOS: install clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SANITIZE_ASAN_UBSAN": "ON"
      }
    },

    {
      "name": "tsan",
      "inherits": "base",
      "displayName": "Debug + TSan (default compiler)",
      "description": "Requires Clang or GCC; TSan is Linux/macOS only",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SANITIZE_TSAN": "ON"
      }
    },

    {
      "name": "tsan-clang",
      "inherits": "base-clang",
      "displayName": "Debug + TSan (Clang, Linux/macOS only)",
      "description": "TSan is not available on Windows regardless of compiler",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SANITIZE_TSAN": "ON"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug",            "configurePreset": "debug"            },
    { "name": "release",          "configurePreset": "release"          },
    { "name": "asan-ubsan",       "configurePreset": "asan-ubsan"       },
    { "name": "asan-ubsan-clang", "configurePreset": "asan-ubsan-clang" },
    { "name": "tsan",             "configurePreset": "tsan"             },
    { "name": "tsan-clang",       "configurePreset": "tsan-clang"       }
  ],

  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "asan-ubsan-clang",
      "configurePreset": "asan-ubsan-clang",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "tsan-clang",
      "configurePreset": "tsan-clang",
      "output": { "outputOnFailure": true }
    }
  ]
}
